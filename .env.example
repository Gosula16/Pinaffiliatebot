# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# PinAffiliateBot — Environment Variables
# Copy this file to .env and fill in your keys
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Amazon PAAPI (get from Associates Central > Tools > Product Advertising API)
AMAZON_ACCESS_KEY=your_amazon_access_key_here
AMAZON_SECRET_KEY=your_amazon_secret_key_here
AMAZON_PARTNER_TAG=yourtag-21

# Pinterest (get from developers.pinterest.com > Create App)
PINTEREST_ACCESS_TOKEN=your_pinterest_oauth_token_here

# Pinterest Board IDs (get from your board URL: pinterest.com/yourname/board-name/)
BOARD_TECH=your_tech_board_id
BOARD_HOME=your_home_board_id
BOARD_FITNESS=your_fitness_board_id
BOARD_DEALS=your_deals_board_id

# Anthropic API (get from console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Bot Settings (optional — defaults are fine to start)
MAX_PINS_PER_DAY=15
MIN_DELAY_SEC=180
MAX_DELAY_SEC=420
