# PinAffiliateBot - Environment Variables
# Copy this file to .env locally, or add the same names as GitHub Actions secrets.
# NEVER commit your .env file to git.

# Amazon PAAPI
# Get these from Associates Central > Tools > Product Advertising API.
# If PAAPI is not active yet, the bot will try the scrape fallback.
AMAZON_ACCESS_KEY=your_amazon_access_key_here
AMAZON_SECRET_KEY=your_amazon_secret_key_here
AMAZON_PARTNER_TAG=yourtag-21

# Pinterest OAuth token
# Get this from developers.pinterest.com > Your App > Generate Token.
# Required scopes: pins:read, pins:write, boards:read.
PINTEREST_ACCESS_TOKEN=your_pinterest_oauth_token_here

# Pinterest Board IDs
# Use Pinterest API board IDs, not board names or URLs.
# You can also call GET https://api.pinterest.com/v5/boards with your token.
BOARD_TECH=your_tech_board_id_number
BOARD_HOME=your_home_board_id_number
BOARD_FITNESS=your_fitness_board_id_number
BOARD_DEALS=your_deals_board_id_number

# Google Gemini
# Get this from https://aistudio.google.com/app/apikey.
GEMINI_API_KEY=your_gemini_api_key_here

# Telegram alerts - optional
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Bot settings
MAX_PINS_PER_DAY=15
PINS_PER_RUN=5
MIN_DELAY_SEC=180
MAX_DELAY_SEC=420
